# Copy to .env and fill in. Never commit .env.
# In Astro, ONLY variables prefixed with PUBLIC_ are exposed to the browser.

# Postmark — transactional email for the contact form.
# SERVER-SIDE ONLY. No PUBLIC_ prefix, so the token never reaches the browser.
POSTMARK_SERVER_TOKEN=
CONTACT_TO_EMAIL=        # where form notifications go (RemoteKind inbox)
CONTACT_FROM_EMAIL=      # a Postmark-verified sender address

# Calendly — booking link. Safe to expose, so it uses the PUBLIC_ prefix.
PUBLIC_CALENDLY_URL=