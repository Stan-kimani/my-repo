# Copy to .env and fill in. Never commit .env.
# In Astro, ONLY variables prefixed with PUBLIC_ are exposed to the browser.
#
# For BUILDING now, the placeholder values below are safe. Swap all of them for
# real values before the site goes live (see planning/roadmap.md pre-launch checklist).

# Postmark — transactional email for the contact form. SERVER-SIDE ONLY (no PUBLIC_ prefix).
# DEV PLACEHOLDER: POSTMARK_API_TEST is Postmark's official test token — the endpoint returns
# success WITHOUT sending real email, so you can build/test the whole flow with no account.
POSTMARK_SERVER_TOKEN=POSTMARK_API_TEST
CONTACT_TO_EMAIL=hello@remotekind.com        # PLACEHOLDER — real inbox before launch
CONTACT_FROM_EMAIL=hello@remotekind.com      # PLACEHOLDER — must be a Postmark-verified sender

# Calendly — booking link. Safe to expose (PUBLIC_ prefix).
PUBLIC_CALENDLY_URL=https://calendly.com/remotekind/discovery-call   # PLACEHOLDER