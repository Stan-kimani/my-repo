---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found — RemoteKind" description="This page doesn't exist. Find your way back to RemoteKind.">
	<section class="mx-auto max-w-2xl px-6 py-24 text-center">
		<p class="font-heading text-lg text-deep-gold">404</p>
		<h1 class="mt-2 text-3xl font-medium md:text-4xl">We couldn't find that page.</h1>
		<p class="mx-auto mt-4 max-w-md leading-relaxed">
			The page you're looking for may have moved or no longer exists.
		</p>
		<a
			href="/"
			class="mt-8 inline-block rounded bg-brand-gold px-8 py-3 font-medium text-brand-charcoal hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-charcoal"
		>
			Back to home
		</a>
	</section>
</Layout>
