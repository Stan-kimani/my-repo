---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CtaBand from "../components/CtaBand.astro";
import founder1 from "../assets/founder-1.jpg";

const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL || "https://calendly.com/remotekind/discovery-call";

const points = [
	{
		lead: "2–3 years of real executive support experience",
		rest: "every operator, no exceptions.",
	},
	{
		lead: "A four-stage skills test",
		rest: "cleared before anyone reaches your shortlist.",
	},
	{
		lead: "People I'd trust inside my own business",
		rest: "I place operators who make a founder's life measurably lighter, not someone who's merely available.",
	},
];
---

<Layout
	title="About — RemoteKind"
	description="Meet Mary, the founder behind RemoteKind, and the personal standard every operator has to meet before they ever reach your shortlist."
>
	<Hero
		eyebrow="Hi, I'm Mary"
		heading="I know both sides — because I've lived both sides."
		subhead="I'm a Kenyan founder building RemoteKind from Bangkok. For the past four years I've worked at the center of the remote work industry — training operators to perform at a high level, and helping entrepreneurs find the ones actually worth hiring."
	>
		<div slot="media" class="mx-auto mb-8 aspect-[4/5] w-full max-w-xs overflow-hidden rounded">
			<Image
				src={founder1}
				alt="Mary, founder of RemoteKind"
				width={480}
				height={600}
				class="h-full w-full object-cover"
			/>
		</div>
	</Hero>

	<section class="bg-neutral-cream px-6 py-16">
		<div class="mx-auto max-w-3xl">
			<h2 class="text-2xl md:text-3xl">Why I started RemoteKind</h2>
			<p class="mt-4 leading-relaxed">
				I've spent the last four years inside the remote work world — not observing it,
				building in it. I train virtual assistants and operators to do genuinely excellent
				work, and I've watched the other side of that equation up close: talented founders
				buried in tasks they should never touch, hiring on hope, and paying for it in burnout
				and lost momentum.
			</p>
			<p class="mt-4 leading-relaxed">
				The problem was never a shortage of talent. It was the gap between the founders who
				needed leverage and the operators good enough to deliver it — with no reliable bridge
				between them. Volume isn't the answer. The right person is.
			</p>
			<p class="mt-4 leading-relaxed">I built the thing I wished existed on both sides of the table.</p>
		</div>
	</section>

	<section class="bg-brand-lavender/20 px-6 py-20 text-center">
		<p class="mx-auto max-w-3xl font-heading text-3xl leading-snug text-neutral-ink md:text-4xl">
			&ldquo;&lsquo;Available&rsquo; and &lsquo;excellent&rsquo; are not the same word.&rdquo;
		</p>
	</section>

	<section class="px-6 py-16">
		<div class="mx-auto max-w-3xl">
			<h2 class="text-2xl md:text-3xl">The bar I hold</h2>
			<p class="mt-4 leading-relaxed">That's why RemoteKind holds a hard line on quality:</p>
			<ul class="mt-8 space-y-6">
				{
					points.map((point) => (
						<li class="border-l-2 border-brand-sage pl-4">
							<p class="leading-relaxed">
								<strong class="text-neutral-ink">{point.lead}</strong> — {point.rest}
							</p>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<CtaBand heading="Let's find your person" ctaLabel="Book a call" ctaHref={calendlyUrl} />
</Layout>
