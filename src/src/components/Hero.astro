---
interface Props {
	eyebrow?: string;
	heading: string;
	subhead?: string;
	ctaLabel?: string;
	ctaHref?: string;
	secondaryLabel?: string;
	secondaryHref?: string;
}

const { eyebrow, heading, subhead, ctaLabel, ctaHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="mx-auto max-w-4xl px-6 py-16 text-center md:py-24">
	<slot name="media" />
	{eyebrow && <p class="mb-2 font-body text-sm font-medium uppercase tracking-wide text-deep-gold">{eyebrow}</p>}
	<h1 class="text-3xl font-medium md:text-4xl xl:text-5xl">{heading}</h1>
	{subhead && <p class="mx-auto mt-6 max-w-2xl leading-relaxed">{subhead}</p>}
	{
		ctaLabel && ctaHref && (
			<div class="mt-8">
				<a
					href={ctaHref}
					class="inline-block rounded bg-brand-gold px-8 py-3 font-medium text-brand-charcoal hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-charcoal"
				>
					{ctaLabel}
				</a>
			</div>
		)
	}
	{
		secondaryLabel && secondaryHref && (
			<p class="mt-4">
				<a href={secondaryHref} class="text-deep-sage hover:text-brand-charcoal">
					{secondaryLabel}
				</a>
			</p>
		)
	}
</section>
