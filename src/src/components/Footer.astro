---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "How It Works", href: "/how-it-works" },
	{ label: "About", href: "/about" },
	{ label: "Contact", href: "/contact" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-line bg-neutral-cream">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-12 text-center">
		<a href="/" aria-label="RemoteKind home">
			<Image src={logo} alt="RemoteKind" width={140} height={140} class="h-auto w-24 md:w-32" />
		</a>
		<nav aria-label="Footer">
			<ul class="flex flex-wrap justify-center gap-6 font-body text-neutral-body">
				{
					navItems.map((item) => (
						<li>
							<a
								href={item.href}
								class="hover:text-deep-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-charcoal"
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<p class="font-body text-sm text-neutral-muted">&copy; {year} RemoteKind. All rights reserved.</p>
	</div>
</footer>
