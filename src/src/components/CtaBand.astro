---
interface Props {
	heading: string;
	body?: string;
	ctaLabel: string;
	ctaHref?: string;
}

const { heading, body, ctaLabel, ctaHref } = Astro.props;
---

<section class="border-t border-neutral-line bg-neutral-cream px-6 py-16 text-center">
	<h2 class="text-2xl md:text-3xl">{heading}</h2>
	{body && <p class="mx-auto mt-4 max-w-2xl leading-relaxed">{body}</p>}
	<div class="mt-8">
		<a
			href={ctaHref}
			class="inline-block rounded bg-brand-gold px-8 py-3 font-medium text-brand-charcoal hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-charcoal"
		>
			{ctaLabel}
		</a>
	</div>
</section>
